APP_WORKSPACE="app/Sunclub.xcworkspace"
APP_SCHEME="Sunclub"
APP_IDENTIFIER="app.peyton.sunclub"

DEFAULT_SIMULATOR_DEVICE="iPhone 17 Pro"
RUN_SIMULATOR_NAME="Sunclub Run iPhone 17 Pro"
TEST_SIMULATOR_NAME="Sunclub Test iPhone 17 Pro"
SCREENSHOT_SIMULATOR_PREFIX="Sunclub Screenshots"

RUN_APP_PATH="Build/Products/Debug-iphonesimulator/Sunclub.app"
TEST_XCODEBUILD_ARGS="-parallel-testing-enabled NO -maximum-parallel-testing-workers 1"

BUILD_DERIVED_DATA=".DerivedData/build"
RUN_DERIVED_DATA=".DerivedData/run"
TEST_DERIVED_DATA=".DerivedData/test"
SCREENSHOT_DERIVED_DATA=".DerivedData/screenshots"
ARCHIVE_DERIVED_DATA=".DerivedData/archive"

ARCHIVE_PATH=".build/Sunclub.xcarchive"
EXPORT_PATH=".build/export"
EXPORT_OPTIONS_PATH="scripts/appstore/ExportOptions.plist"
TEAM_ID="3VDQ4656LX"
