graph TD
    subgraph Onboarding ["Onboarding (First Launch)"]
        W[WelcomeView<br/>Logo + Get Started] -->|Get Started| EN[EnableNotificationsView<br/>Bell + Enable Button]
        EN -->|Enable Notifications| H
    end

    subgraph Main ["Main App"]
        H[HomeView<br/>Greeting + Today Card<br/>Streak Card + Verify Button]
        H -->|Verify Now| LV[LiveVerifyView<br/>Camera + FastVLM<br/>2x YES → Confirm]
        LV -->|Detection Success| VS[VerificationSuccessView<br/>Checkmark + Streak]
        VS -->|Done| H
        H -->|Tap Streak Card| WR[WeeklyReportView<br/>7-day summary<br/>Applied grid + Missed list]
        WR -->|Back| H
        H -->|Gear Icon| S[SettingsView<br/>Reminder Time<br/>Manage Subscription]
        S -->|Back| H
    end

    subgraph Notifications ["Notification Deep Links"]
        DN[Daily Notification<br/>Verify Now action] -->|Opens App| LV
        WN[Weekly Notification<br/>Summary available] -->|Opens App| WR
    end

    subgraph "Proposed New Flows"
        H -.->|New: History| HIS[HistoryView<br/>Month calendar<br/>Day detail on tap]
        HIS -.->|Back| H
        H -.->|New: Log Manually| MC[Manual Confirmation<br/>One-tap logging]
        MC -.->|Confirmed| VS
        LV -.->|New: After Success| RA[Reapply Timer<br/>2hr reminder set]
    end

    style W fill:#faf6f0,stroke:#1d1915,color:#1d1915
    style EN fill:#fdecc2,stroke:#1d1915,color:#1d1915
    style H fill:#faf6f0,stroke:#faa30c,color:#1d1915,stroke-width:3px
    style LV fill:#1d1915,stroke:#faa30c,color:#faf6f0
    style VS fill:#268948,stroke:#1d1915,color:#faf6f0
    style WR fill:#faf6f0,stroke:#1d1915,color:#1d1915
    style S fill:#faf6f0,stroke:#1d1915,color:#1d1915
    style DN fill:#fdecc2,stroke:#1d1915,color:#1d1915
    style WN fill:#fdecc2,stroke:#1d1915,color:#1d1915
    style HIS fill:#faf6f0,stroke:#faa30c,color:#1d1915,stroke-dasharray:5 5
    style MC fill:#faf6f0,stroke:#faa30c,color:#1d1915,stroke-dasharray:5 5
    style RA fill:#fdecc2,stroke:#faa30c,color:#1d1915,stroke-dasharray:5 5
