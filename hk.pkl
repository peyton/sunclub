/// Sunclub tooling checks.
/// The root wrappers choose which steps run so local and CI behavior stays explicit.
amends "package://github.com/jdx/hk/releases/download/v1.39.0/hk@1.39.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.39.0/hk@1.39.0#/Builtins.pkl"

local toolSteps = new Mapping<String, Step> {
  ["markdown"] = (Builtins.rumdl) {}
  ["pkl"] = Builtins.pkl
  ["pkl-format"] = (Builtins.pkl_format) {
    depends = "pkl"
  }
  ["shellcheck"] = Builtins.shellcheck
  ["shfmt"] = Builtins.shfmt
  ["prettier"] = (Builtins.prettier) {
    dir = "."
    batch = true
  }
  ["ruff"] = (Builtins.ruff) {
    batch = true
  }
  ["ruff_format"] = (Builtins.ruff_format) {
    depends = "ruff"
  }
}

hooks {
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps {
      ...toolSteps
    }
  }
  ["check"] {
    steps {
      ...toolSteps
    }
  }
  ["fix"] {
    fix = true
    steps {
      ...toolSteps
    }
  }
}
